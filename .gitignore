# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Local virtualenv (VPS uses its own; the local one is just for memo_smoke et al)
.venv/
venv/

# Local env files. The VPS .env is never in the repo (deploy.sh excludes it).
# .env.test is also excluded because it has host-specific paths.
.env
.env.*
!.env.example

# Per-day worktrees (their MEMORY.md is generated at runtime; never tracked).
worktrees/

# Bot runtime artefacts
logs/
snapshots/
JOURNAL/
state/
MEMORY.md
MEMORY.md.archived-*

# Personal reference docs (not shipped). docs/ is now git-ignored by
# design; the only docs that ship with the repo are README.md and
# docs/architecture.md. Anything else in docs/ is operator-only.
docs/001-*
docs/002-*
docs/003-*
docs/004-*
docs/005-*

# Editor / IDE
*.swp
*.swo
*~
.vscode/
.idea/

# Python tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Telethon session files used by scripts/telegram_live_smoke.py. The
# session is the user's login state — never commit it.
.telegram-live-smoke*
*.session
*.session-journal
