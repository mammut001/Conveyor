# =============================================================================
# Conveyor — .env.example
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Telegram Bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_ALLOWED_USER_ID=123456789

# -----------------------------------------------------------------------------
# Required: Codex CLI
# -----------------------------------------------------------------------------
CODEX_WORKSPACE_ROOT=/srv/my-repo
CODEX_BIN=/usr/local/bin/codex

# -----------------------------------------------------------------------------
# Optional: Feishu/Lark Bot (for Feishu channel)
# -----------------------------------------------------------------------------
# LARK_APP_ID=cli_xxx
# LARK_APP_SECRET=replace_me
# LARK_ALLOWED_OPEN_ID=ou_xxx

# -----------------------------------------------------------------------------
# Optional: Timezone
# -----------------------------------------------------------------------------
# IANA timezone for "today" boundaries, daily briefing, scheduler.
# Default: America/Toronto
# USER_TIMEZONE=America/Toronto

# -----------------------------------------------------------------------------
# Optional: Operator Profile
# -----------------------------------------------------------------------------
# Used by the agent's <operator-profile> block, injected into every prompt.
# All four are optional; defaults in config.py are documented inline.
# OPERATOR_NAME=
# OPERATOR_LANGUAGE=zh-CN
# OPERATOR_STYLE=terse
# OPERATOR_STANDING=personal-scale, single operator

# -----------------------------------------------------------------------------
# Optional: Codex Behavior
# -----------------------------------------------------------------------------
# CODEX_TASK_ROOT=/srv/conveyor
# CODEX_MEMORY_ROOT=~/.codex
# CODEX_MODEL=
# CODEX_TIMEOUT_SECONDS=3600
# TELEGRAM_PROGRESS_SECONDS=3
# CODEX_RETRY_429_DELAYS_SECONDS=300,900,1800

# -----------------------------------------------------------------------------
# Optional: Conveyor UX
# -----------------------------------------------------------------------------
# Progress mode: verbose | compact (default) | quiet
# CONVEYOR_PROGRESS_MODE=compact
# Session memory: recent turns for "继续" / "continue"
# CONVEYOR_SESSION_ENABLED=true
# CONVEYOR_SESSION_MAX_TURNS=20
# CONVEYOR_SESSION_INJECT_TURNS=5

# -----------------------------------------------------------------------------
# Optional: Gmail (App Password backend, P3.3)
# -----------------------------------------------------------------------------
# GMAIL_BACKEND=imap_smtp
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PASSWORD=abcd1234efgh5678
# GMAIL_IMAP_HOST=imap.gmail.com
# GMAIL_IMAP_PORT=993
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=587

# -----------------------------------------------------------------------------
# Optional: Google OAuth (Calendar + Contacts, P3.4)
# -----------------------------------------------------------------------------
# Gmail stays App Password; OAuth only for Calendar/Contacts.
# GOOGLE_CLIENT_SECRET_PATH=/opt/conveyor/secrets/client_secret.json
# GOOGLE_TOKEN_PATH=/opt/conveyor/secrets/google_token.json
# GOOGLE_OAUTH_SCOPES=
# GOOGLE_OAUTH_REDIRECT_PORT=8765

# -----------------------------------------------------------------------------
# Optional: GitHub (Issues/PRs/CI, P3.6)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_DEFAULT_REPO=owner/repo
# GITHUB_API_BASE=https://api.github.com

# -----------------------------------------------------------------------------
# Optional: Daily Briefing (P3.5)
# -----------------------------------------------------------------------------
# BRIEFING_ENABLED=false
# BRIEFING_HOUR=8
# BRIEFING_MINUTE=0
# BRIEFING_CHANNEL=telegram
# BRIEFING_CHAT_ID=

# -----------------------------------------------------------------------------
# Optional: Scheduler (P3.2)
# -----------------------------------------------------------------------------
# SCHEDULER_ENABLED=true
# SCHEDULER_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# Optional: Web Fetch (P4.1)
# -----------------------------------------------------------------------------
# WEB_FETCH_ENABLED=true
# WEB_FETCH_TIMEOUT_SECONDS=10
# WEB_FETCH_MAX_BYTES=2000000
# WEB_FETCH_MAX_REDIRECTS=3  # Note: Redirects are currently disabled (--no-location)
# WEB_USER_AGENT=ConveyorBot/0.1

# -----------------------------------------------------------------------------
# Optional: Web Search (P4.1)
# -----------------------------------------------------------------------------
# Backend: disabled | searxng | brave | tavily | serper
# WEB_SEARCH_BACKEND=disabled
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_ENDPOINT=
# WEB_SEARCH_MAX_RESULTS=8

# -----------------------------------------------------------------------------
# Optional: Research (P4.1)
# -----------------------------------------------------------------------------
# RESEARCH_MAX_SOURCES=5
# RESEARCH_FETCH_TOP_N=5
# RESEARCH_MAX_CHARS_PER_SOURCE=6000

# -----------------------------------------------------------------------------
# Optional: File Search / Knowledge Base (P4.2)
# -----------------------------------------------------------------------------
# FILE_SEARCH_ENABLED=true
# FILE_SEARCH_ALLOWED_ROOTS=/path/to/extra/root1,/path/to/root2
# FILE_SEARCH_MAX_FILE_BYTES=1000000
# FILE_SEARCH_MAX_RESULTS=10
# FILE_SEARCH_EXTENSIONS=.md,.txt,.py,.ts,.tsx,.js,.json,.yaml,.yml,.toml
# KB_ROOT=~/.codex/kb
# KB_INDEX_PATH=~/.codex/kb_index.sqlite

# -----------------------------------------------------------------------------
# Optional: Execution Nodes (P5.0 — phase 0 foundation)
# -----------------------------------------------------------------------------
# The Conveyor control plane always runs on the VPS and owns
# Codex + server-side tools. This section opts the bot into also
# tracking a *stub* desktop node for the operator's MacBook.
#
# The desktop node is offline and stubbed in this phase — no
# screenshot, no mouse, no keyboard, no browser control, no
# Gemini Computer Use call. See docs/desktop_agent_protocol.md
# and docs/desktop_security.md for the future plan.
#
# CONVEYOR_DESKTOP_NODE_ENABLED=false
# CONVEYOR_DESKTOP_NODE_ID=macbook-payton
# CONVEYOR_DESKTOP_NODE_NAME=Payton MacBook
# CONVEYOR_DESKTOP_AGENT_TOKEN=replace_me_with_long_random_string
# CONVEYOR_COMPUTER_USE_DEFAULT_MODE=observe_only  # observe_only | off
