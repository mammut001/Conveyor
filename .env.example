TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_ALLOWED_USER_ID=123456789
CODEX_WORKSPACE_ROOT=/srv/my-repo
CODEX_BIN=/usr/local/bin/codex

# Feishu/Lark bot (feishu_bot.py). Optional for Telegram-only deploys.
# LARK_APP_ID=cli_xxx
# LARK_APP_SECRET=replace_me
# LARK_ALLOWED_OPEN_ID=ou_xxx

# IANA timezone for "today" boundaries (worktree-per-day, daily MEMORY.md
# compression hour gate). Defaults to America/Toronto.
# USER_TIMEZONE=America/Toronto

# Operator profile (onboarding-A). Used by the agent's
# <operator-profile> block, injected into every prompt so the agent
# always knows who it's talking to, what language, what tone.
# All four are optional; defaults in config.py are documented inline.
# OPERATOR_NAME=
# OPERATOR_LANGUAGE=zh-CN
# OPERATOR_STYLE=terse
# OPERATOR_STANDING=personal-scale, single operator

# Optional overrides
# OPENAI_API_KEY=sk-replace_me
# MINIMAX_API_KEY=sk-replace_me
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# CODEX_TASK_ROOT=/srv/conveyor
# CODEX_MODEL=
# CODEX_TIMEOUT_SECONDS=3600
# How often we edit the placeholder with fresh prose. 3s = near-real-time
# on Telegram 20 edits/min limit; 20s (old default) felt frozen.
# TELEGRAM_PROGRESS_SECONDS=3
# CODEX_RETRY_429_DELAYS_SECONDS=300,900,1800
