# /etc/default/codex-telegram-runner
#
# Optional override file for the systemd units in this directory.
# Copy to /etc/default/codex-telegram-runner (without the .example
# suffix) and edit to override the install path. The systemd units
# default to /opt/codex-telegram-runner if this file is missing.
#
# After editing, reload systemd and restart the affected units:
#   sudo systemctl daemon-reload
#   sudo systemctl restart codex-telegram-bot.service
#   sudo systemctl restart codex-telegram-maintain.service
#
# /srv and /home/ubuntu in the .service files' ReadWritePaths are
# intentional VPS paths (snapshot + codex home); if you install on a
# machine with a different layout, edit the .service files directly.

# Install path of the cloned repo. Must be an absolute path.
# CODEX_TELEGRAM_DIR=/opt/codex-telegram-runner
